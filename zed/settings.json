{
  // Appearance
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Mocha - No Italics",
  },
  "icon_theme": "Catppuccin Mocha",
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 15.7,
  "ui_font_size": 18.0,
  "cursor_blink": false,
  "current_line_highlight": "none",
  "indent_guides": {
    "enabled": false,
  },
  "scrollbar": {
    "axes": {
      "horizontal": false,
    },
  },

  // Editor behavior
  "vim_mode": true,
  "soft_wrap": "editor_width",
  "preferred_line_length": 120,
  "hover_popover_enabled": false,
  "show_completions_on_input": false,
  "restore_on_startup": "empty_tab",

  // Edit predictions
  "edit_predictions": {
    "mode": "subtle",
    "copilot": {
      "enable_next_edit_suggestions": true,
    },
    "provider": "copilot",
  },

  // Git
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },

  // Tabs
  "tabs": {
    "git_status": true,
  },

  // Languages
  "languages": {
    "Markdown": {
      "show_edit_predictions": false,
      "hard_wrap": "none",
    },
    "PHP": {
      "language_servers": ["intelephense", "!phpactor", "!phptools", "..."],
      "formatter": "language_server",
      "format_on_save": "off",
    },
  },

  // Terminal
  "terminal": {
    "copy_on_select": true,
    "shell": {
      "with_arguments": {
        "program": "/usr/local/bin/fish",
        "args": ["--interactive"],
      },
    },
  },

  // Agent
  "agent": {
    "default_profile": "ask",
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "claude-opus-4.6",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-4.6",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5.4",
        "enable_thinking": false
      }
    ],
    "enable_feedback": false,
    "default_height": 500,
    "dock": "bottom",
    "default_model": {
      "effort": "high",
      "provider": "copilot_chat",
      "model": "gpt-5.4",
    },
  },

  // Telemetry & UI panels
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "collaboration_panel": {
    "button": false,
  },
  "which_key": {
    "enabled": true,
  },
  "file_scan_exclusions": ["**/.git", "**/.DS_Store", "**/.settings", "**/node_modules", "**/vendor"],
}
