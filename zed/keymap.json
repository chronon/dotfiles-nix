[
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-p": "file_finder::Toggle",
      "ctrl-/": "terminal_panel::ToggleFocus",
      "ctrl-a -": "terminal_panel::ToggleFocus",
      ", e": "project_panel::ToggleFocus",
    },
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      ", e": "workspace::ToggleLeftDock",
    },
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "shift-k": "editor::Hover",
      ", b d": "pane::CloseActiveItem",
      ", c f": "editor::Format",
      ", c r": "editor::Rename",
      ", c x": "editor::Copy",
      ", s s": "outline::Toggle",
      "[ h": "editor::GoToPreviousChange",
      "] h": "editor::GoToNextChange",
      "[ [": "editor::GoToPreviousReference",
      "] ]": "editor::GoToNextReference",
    },
  },
]
